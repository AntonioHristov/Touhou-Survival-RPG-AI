        "Easy": {
            "intention": "Could survive and perhaps win any individual encounter even without weapons"
        },
        "Normal": {
            "intention": "Good chance to survive and perhaps win encounters that would be rare to survive in Hard difficulty, but without total abuse (starting state could beat youkais like Rumia or Cirno, but rare to beat Yukari or Hecatia)."
        },
        "Hard": {
            "intention": "Be realistic (merciless but without exaggerating player adversities)."
        }
    },
